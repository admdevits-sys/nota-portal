# =============================================================================
# Nota Portal - Gitignore
# =============================================================================

# --------------
# Dependências
# --------------
node_modules/
.pnpm-store/
.yarn/

# --------------
# Build outputs
# --------------
dist/
build/
.output/

# --------------
# Environment
# --------------
.env
.env.*
!.env.example
!.env.example.local

# --------------
# Logs
# --------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------
# Editor & IDE & Dev tools
# --------------
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------------
# Test coverage
# --------------
coverage/
.nyc_output/

# --------------
# Cache
# --------------
.cache/
.parcel-cache/
.turbo/

# --------------
# Backend - Prisma
# --------------
backend/prisma/*.db
backend/prisma/*.db-journal
backend/prisma/migrations/*.sql

# --------------
# Backend - Compilação
# --------------
*.tsbuildinfo

# --------------
# Frontend - Vite
# --------------
frontend/src/services/api.ts
*.tsbuildinfo

# --------------
# Temporary files
# --------------
tmp/
temp/
*.tmp
*.temp

# --------------
# Cloud sync folders
# --------------
.OneDrive/
.OneDrive*/
Dropbox/
iCloud/
Google\ Drive/
~$*.xlsx
~$*.docx
~$*.pptx

# --------------
# Secrets & keys (NUNCA commitar)
# --------------
*.pem
*.key
credentials.json
service-account.json
